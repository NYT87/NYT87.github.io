---
/** biome-ignore-all lint/correctness/noUnusedVariables: they are used in the layout for structured data */
interface Props {
	title: string;
	description?: string;
	image?: string;
	noindex?: boolean;
}

const {
	title,
	description = "NYT87 is a remote software development company building reliable web applications, backend systems, and cloud infrastructure.",
	image = "/assets/brand.png",
	noindex = false,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(image, Astro.site);
const robotsContent = noindex ? "noindex,nofollow" : "index,follow";
---

<!doctype html>
<html lang="en-US">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="robots" content={robotsContent} />
		<meta name="theme-color" media="(prefers-color-scheme: light)" content="#f6f2ed" />
		<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#2b3037" />
		<meta name="color-scheme" content="light dark" />
		<link rel="canonical" href={canonicalUrl} />

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="NYT87" />
		<meta property="og:image" content={ogImageUrl} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="preload"
			as="style"
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap"
		/>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Space+Grotesk:wght@500;700&display=swap"
		/>
		<slot name="head" />
		<title>{title}</title>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to content</a>
		<slot />
	</body>
</html>

<style is:global>
	@font-face {
		font-family: "Manrope Fallback";
		font-style: normal;
		font-weight: 400;
		src: local("Arial");
		ascent-override: 90%;
		descent-override: 22%;
		line-gap-override: 0%;
		size-adjust: 106%;
	}

	@font-face {
		font-family: "Space Grotesk Fallback";
		font-style: normal;
		font-weight: 500;
		src: local("Arial");
		ascent-override: 94%;
		descent-override: 20%;
		line-gap-override: 0%;
		size-adjust: 102%;
	}

	:root {
		color-scheme: light dark;
		--bg: oklch(0.97 0.01 70);
		--surface: oklch(0.99 0.008 70);
		--surface-strong: oklch(1 0.004 70);
		--surface-muted: oklch(0.965 0.008 70);
		--text: oklch(0.2 0.01 70);
		--muted: oklch(0.46 0.015 70);
		--border: oklch(0.84 0.01 70 / 0.82);
		--line-strong: oklch(0.74 0.014 70 / 0.9);
		--brand: oklch(0.63 0.18 45);
		--brand-strong: oklch(0.56 0.17 43);
		--accent: oklch(0.54 0.08 208);
		--accent-soft: oklch(0.95 0.018 208 / 0.92);
		--brand-soft: oklch(0.95 0.028 45 / 0.9);
		--focus-ring: oklch(0.72 0.16 45 / 0.9);
		--shadow: 0 16px 34px oklch(0.24 0.02 60 / 0.07);
		--shadow-sm: 0 6px 18px oklch(0.24 0.02 60 / 0.045);
		--accent-wash: color-mix(in oklch, var(--accent) 8%, transparent);
		--accent-wash-strong: color-mix(in oklch, var(--accent) 12%, transparent);
		--brand-shadow: oklch(0.5 0.06 208 / 0.1);
		--radius-lg: 26px;
		--radius-md: 18px;
		--radius-sm: 12px;
		--font-heading: "Space Grotesk", "Space Grotesk Fallback", sans-serif;
		--font-body: "Manrope", "Manrope Fallback", sans-serif;
		--section-anchor-offset: 4rem;
		--space-1: 0.4rem;
		--space-2: 0.7rem;
		--space-3: 1rem;
		--space-4: 1.4rem;
		--space-5: 2rem;
		--space-6: 2.8rem;
		--max-width: 1120px;
		--page-gutter: clamp(1rem, 3vw, 1.4rem);
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		min-height: 100%;
	}

	html {
		scroll-padding-top: 0;
	}

	body {
		font-family: var(--font-body);
		color: var(--text);
		background:
			linear-gradient(180deg, oklch(1 0 0 / 0.08), oklch(1 0 0 / 0) 11rem),
			radial-gradient(circle at 12% 10%, oklch(0.93 0.02 208 / 0.18), transparent 32%),
			radial-gradient(circle at 88% 18%, oklch(0.94 0.025 45 / 0.14), transparent 36%), var(--bg);
		line-height: 1.65;
		text-rendering: optimizeLegibility;
		-webkit-font-smoothing: antialiased;
	}

	h1,
	h2,
	h3,
	h4 {
		font-family: var(--font-heading);
		letter-spacing: -0.03em;
		line-height: 1.1;
		margin: 0;
		overflow-wrap: anywhere;
		hyphens: auto;
		text-wrap: balance;
	}

	p {
		margin: 0;
		color: var(--muted);
		font-size: clamp(1rem, 0.96rem + 0.2vw, 1.1rem);
		overflow-wrap: break-word;
		hyphens: auto;
	}

	a {
		text-decoration: none;
		color: inherit;
	}

	img,
	picture {
		max-width: 100%;
	}

	main {
		display: block;
		max-width: 100%;
	}

	.container {
		width: min(100%, calc(var(--max-width) + (var(--page-gutter) * 2)));
		padding-inline: var(--page-gutter);
		margin-inline: auto;
	}

	.section {
		padding: 1rem 0 clamp(3rem, 6vw, 5.25rem);
		scroll-margin-top: var(--section-anchor-offset);
	}

	.section-head {
		display: grid;
		gap: 1rem;
		margin-bottom: clamp(1.8rem, 3vw, 2.8rem);
	}

	.section-kicker {
		display: inline-flex;
		width: fit-content;
		max-width: 100%;
		padding: 0.38rem 0.8rem;
		border-radius: 999px;
		font-weight: 700;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		white-space: normal;
		overflow-wrap: anywhere;
		background: var(--brand-soft);
		color: color-mix(in oklch, var(--brand) 88%, var(--text));
	}

	.section-title {
		font-size: clamp(2rem, 1.4rem + 2vw, 3.2rem);
	}

	.panel {
		background: linear-gradient(180deg, var(--surface-strong), var(--surface));
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0.85rem 1.4rem;
		border-radius: 999px;
		font-family: var(--font-heading);
		font-weight: 500;
		font-size: 0.94rem;
		letter-spacing: 0.01em;
		transition:
			transform 0.24s ease,
			box-shadow 0.24s ease,
			background-color 0.24s ease,
			color 0.24s ease;
	}

	.btn-primary {
		color: var(--surface-strong);
		background: linear-gradient(135deg, var(--brand-strong), var(--brand));
		box-shadow: 0 8px 18px color-mix(in oklch, var(--brand) 22%, transparent);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 22px color-mix(in oklch, var(--brand) 26%, transparent);
	}

	.btn-outline {
		border-color: color-mix(in oklch, var(--accent) 28%, var(--border));
		background: color-mix(in oklch, var(--accent) 6%, var(--surface-strong));
		color: var(--accent);
	}

	.btn-outline:hover {
		transform: translateY(-2px);
		background: color-mix(in oklch, var(--accent) 10%, var(--surface-strong));
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: 0;
		transform: translateY(-140%);
		z-index: 200;
		padding: 0.7rem 1rem;
		border-radius: 999px;
		background: var(--text);
		color: var(--surface-strong);
		font-weight: 700;
		transition: transform 0.2s ease;
	}

	.skip-link:focus-visible {
		transform: translateY(1rem);
	}

	:focus-visible {
		outline: 3px solid var(--focus-ring);
		outline-offset: 3px;
	}

	a:focus-visible,
	button:focus-visible,
	summary:focus-visible,
	[tabindex]:focus-visible {
		border-radius: var(--radius-sm);
	}

	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(14px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.reveal {
		animation: fade-up 0.65s ease both;
	}

	.reveal-delay-1 {
		animation-delay: 0.1s;
	}

	.reveal-delay-2 {
		animation-delay: 0.2s;
	}

	.reveal-delay-3 {
		animation-delay: 0.3s;
	}

	@media (prefers-reduced-motion: reduce) {
		* {
			animation-duration: 0.01ms !important;
			animation-iteration-count: 1 !important;
			transition-duration: 0.01ms !important;
			scroll-behavior: auto !important;
		}
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--bg: oklch(0.18 0.01 250);
			--surface: oklch(0.23 0.01 250);
			--surface-strong: oklch(0.26 0.012 250);
			--surface-muted: oklch(0.2 0.012 250);
			--text: oklch(0.94 0.01 80);
			--muted: oklch(0.77 0.015 80);
			--border: oklch(0.4 0.015 250 / 0.7);
			--line-strong: oklch(0.55 0.015 250 / 0.8);
			--brand-soft: oklch(0.36 0.06 45 / 0.24);
			--accent-soft: oklch(0.32 0.035 208 / 0.28);
			--focus-ring: oklch(0.73 0.16 45 / 0.95);
			--shadow: 0 18px 38px oklch(0.02 0.01 250 / 0.34);
			--shadow-sm: 0 8px 20px oklch(0.02 0.01 250 / 0.2);
		}

		body {
			background:
				linear-gradient(180deg, oklch(0.3 0.01 250 / 0.07), oklch(0.18 0.01 250 / 0) 13rem),
				radial-gradient(circle at 10% 8%, oklch(0.3 0.035 208 / 0.1), transparent 34%),
				radial-gradient(circle at 90% 20%, oklch(0.34 0.055 45 / 0.08), transparent 38%), var(--bg);
		}
	}

	@media (max-width: 768px) {
		:root {
			--section-anchor-offset: 5.2rem;
			--page-gutter: 1rem;
		}

		.btn {
			width: 100%;
		}

		.section-kicker {
			width: 100%;
		}
	}
</style>
