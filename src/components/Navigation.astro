---

<nav class="navbar">
	<div class="container nav-content">
		<a href="#" class="logo-link" aria-label="NYT87 home">
			<img src="/assets/logo-icon.png" alt="NYT87 Icon" class="nav-brand-img icon" />
			<img src="/assets/logo-text.png" alt="NYT87 Text" class="nav-brand-img text" />
		</a>
		<div class="nav-links">
			<a href="#about">About</a>
			<a href="#services">Services</a>
			<a href="#projects">Projects</a>
			<a href="#team">Team</a>
		</div>
	</div>
</nav>

<style>
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 60;
		padding-top: 0.85rem;
	}

	.nav-content {
		height: 74px;
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 1.2rem;
		border: 1px solid var(--border);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.78);
		backdrop-filter: blur(10px);
		box-shadow: 0 8px 22px rgba(23, 20, 18, 0.08);
		padding: 0 1rem 0 1.1rem;
	}

	.logo-link {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
	}

	.nav-brand-img {
		height: 24px;
		width: auto;
	}

	.nav-brand-img.icon {
		height: 28px;
	}

	.nav-links {
		display: flex;
		justify-content: flex-end;
		justify-self: end;
		gap: clamp(0.8rem, 2vw, 1.6rem);
		font-family: var(--font-heading);
		font-weight: 700;
		font-size: 0.92rem;
		letter-spacing: 0.02em;
	}

	.nav-links a {
		padding: 0.4rem 0.55rem;
		border-radius: 999px;
		transition: background-color 0.24s ease;
	}

	.nav-links a:hover {
		background: rgba(13, 138, 138, 0.11);
	}

	@media (max-width: 900px) {
		.nav-content {
			grid-template-columns: auto;
			justify-content: space-between;
		}

		.nav-links {
			display: none;
		}
	}

	@media (max-width: 768px) {
		.navbar {
			padding-top: 0.6rem;
		}

		.nav-content {
			height: 64px;
			padding: 0 0.7rem 0 0.85rem;
		}

		.nav-brand-img.text {
			height: 20px;
		}
	}
</style>
