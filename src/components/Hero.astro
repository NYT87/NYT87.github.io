---

---

<header class="hero section">
	<div class="container hero-content">
		<div class="hero-copy reveal">
			<span class="section-kicker">Remote Software Studio</span>
			<h1>Designing and engineering products that survive real-world scale.</h1>
			<p>
				NYT87 partners with teams to build reliable web platforms, backend systems, and cloud
				infrastructure with product-minded execution.
			</p>
			<div class="hero-actions reveal reveal-delay-1">
				<a href="#services" class="btn btn-primary">Explore Services</a>
				<a href="#projects" class="btn btn-outline">See Projects</a>
			</div>
		</div>
		<div class="hero-panel panel reveal reveal-delay-2">
			<img src="/assets/brand.png" alt="NYT87 Wordmark" class="hero-logo" />
			<div class="metrics">
				<div>
					<strong>8+ years</strong>
					<span>remote-first delivery</span>
				</div>
				<div>
					<strong>Global</strong>
					<span>cross-timezone collaboration</span>
				</div>
				<div>
					<strong>Product + Infra</strong>
					<span>end-to-end ownership</span>
				</div>
			</div>
		</div>
	</div>
</header>

<style>
	.hero {
		margin-top: 1.1rem;
		padding-top: clamp(2rem, 7vw, 5.8rem);
		position: relative;
	}

	.hero::after {
		content: "";
		position: absolute;
		right: -120px;
		top: 16%;
		width: 280px;
		height: 280px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(13, 138, 138, 0.22), transparent 64%);
		pointer-events: none;
	}

	.hero-content {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: clamp(1.4rem, 3vw, 2.8rem);
		align-items: stretch;
	}

	.hero-copy {
		display: grid;
		align-content: center;
		gap: 1.2rem;
	}

	.hero-copy h1 {
		font-size: clamp(2.1rem, 1.45rem + 2.5vw, 4rem);
		max-width: 16ch;
	}

	.hero-copy p {
		max-width: 58ch;
	}

	.hero-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.hero-actions .btn {
		width: auto;
	}

	.hero-panel {
		padding: clamp(1.1rem, 2.2vw, 1.8rem);
		display: grid;
		gap: 1.3rem;
		align-content: center;
	}

	.hero-logo {
		max-width: 220px;
		width: 100%;
		height: auto;
		display: block;
		margin-inline: auto;
	}

	.metrics {
		display: grid;
		gap: 0.75rem;
	}

	.metrics div {
		border: 1px solid var(--border);
		border-radius: 14px;
		padding: 0.9rem 1rem;
		background: rgba(255, 255, 255, 0.76);
		display: grid;
		gap: 0.15rem;
	}

	.metrics strong {
		font-family: var(--font-heading);
		font-size: 1rem;
	}

	.metrics span {
		color: var(--muted);
		font-size: 0.9rem;
	}

	@media (max-width: 900px) {
		.hero-content {
			grid-template-columns: 1fr;
		}

		.hero-copy h1 {
			max-width: 100%;
		}
	}

	@media (max-width: 768px) {
		.hero {
			margin-top: 3rem;
			padding-top: 1.2rem;
		}

		.hero::after {
			display: none;
		}

		.hero-actions {
			gap: 0.6rem;
		}
	}
</style>
