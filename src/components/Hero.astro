---

---

<header class="hero section">
	<div class="container hero-content">
		<div class="hero-copy reveal">
			<span class="section-kicker">Remote Software Studio</span>
			<h1>Designing and engineering products that survive real-world scale.</h1>
			<p>
				NYT87 partners with companies that need senior engineering judgment across product delivery,
				backend systems, and cloud infrastructure without the overhead of a bloated consultancy.
			</p>
			<div class="hero-actions reveal reveal-delay-1">
				<a href="#services" class="btn btn-primary">Explore Services</a>
				<a href="#contact" class="btn btn-outline">Start a Conversation</a>
			</div>
		</div>
		<div class="hero-panel panel reveal reveal-delay-2">
			<p class="hero-eyebrow">Operating Notes</p>
			<picture>
				<source srcset="/assets/brand-dark.png" media="(prefers-color-scheme: dark)" />
				<img src="/assets/brand.png" alt="NYT87 Wordmark" class="hero-logo" />
			</picture>
			<div class="hero-log" aria-label="Studio operating principles">
				<div class="hero-log-row">
					<span class="hero-log-label">Delivery</span>
					<p>
						Small senior team, direct communication, and milestones tied to real product outcomes.
					</p>
				</div>
				<div class="hero-log-row">
					<span class="hero-log-label">Systems</span>
					<p>
						Web applications, APIs, platform services, and infrastructure built for maintainability.
					</p>
				</div>
				<div class="hero-log-row">
					<span class="hero-log-label">Mode</span>
					<p>Remote-first collaboration with clear documentation and straightforward execution.</p>
				</div>
			</div>
		</div>
	</div>
</header>

<style>
	.hero {
		margin-top: 1.1rem;
		padding-top: clamp(2rem, 7vw, 5.8rem);
		position: relative;
	}

	.hero::after {
		content: "";
		position: absolute;
		right: -120px;
		top: 16%;
		width: 280px;
		height: 280px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(13, 138, 138, 0.22), transparent 64%);
		pointer-events: none;
	}

	.hero-content {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
		gap: clamp(1.4rem, 3vw, 2.8rem);
		align-items: stretch;
	}

	.hero-copy {
		display: grid;
		align-content: center;
		gap: 1.2rem;
		min-width: 0;
	}

	.hero-copy h1 {
		font-size: clamp(2.2rem, 1.5rem + 2.5vw, 4rem);
		max-width: 12ch;
		max-inline-size: 100%;
		line-height: 1.02;
		letter-spacing: -0.045em;
		overflow-wrap: anywhere;
		text-wrap: balance;
	}

	.hero-copy p {
		max-width: 58ch;
		max-inline-size: 100%;
	}

	.hero-actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.hero-actions .btn {
		width: auto;
	}

	.hero-panel {
		padding: clamp(1.1rem, 2.2vw, 1.8rem);
		display: grid;
		gap: 1rem;
		align-content: center;
		min-width: 0;
		position: relative;
		overflow: hidden;
	}

	.hero-panel::before {
		content: "";
		position: absolute;
		inset: 0 0 auto 0;
		height: 3px;
		background: linear-gradient(90deg, var(--brand), var(--accent));
	}

	.hero-eyebrow {
		font-family: var(--font-heading);
		font-size: 0.8rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.hero-logo {
		max-width: 180px;
		width: 100%;
		height: auto;
		display: block;
		margin-inline: 0;
	}

	.hero-log {
		display: grid;
		gap: 0;
		border-top: 1px solid var(--line-strong);
	}

	.hero-log-row {
		display: grid;
		grid-template-columns: minmax(84px, 110px) 1fr;
		gap: 0.9rem;
		padding: 0.95rem 0;
		border-bottom: 1px solid var(--border);
		align-items: start;
	}

	.hero-log-label {
		font-family: var(--font-heading);
		font-size: 0.82rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--muted);
	}

	.hero-log-row p {
		font-size: 0.96rem;
		max-width: 38ch;
	}

	@media (max-width: 900px) {
		.hero-content {
			grid-template-columns: 1fr;
		}

		.hero-copy h1 {
			max-width: 100%;
		}
	}

	@media (max-width: 768px) {
		.hero {
			margin-top: 3rem;
			padding-top: 1.2rem;
		}

		.hero::after {
			display: none;
		}

		.hero-copy h1 {
			font-size: clamp(1.9rem, 10vw, 3.1rem);
		}

		.hero-copy p {
			font-size: 0.98rem;
		}

		.hero-actions {
			gap: 0.6rem;
		}

		.hero-log-row {
			grid-template-columns: 1fr;
			gap: 0.35rem;
		}
	}
</style>
