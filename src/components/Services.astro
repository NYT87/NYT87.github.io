---
// biome-ignore lint/correctness/noUnusedVariables: they are used in the layout for structured data
const services = [
	{
		icon: "Web",
		title: "Web Applications",
		description:
			"Product-grade frontends and full-stack experiences built for performance, usability, and long-term maintainability.",
	},
	{
		icon: "API",
		title: "Backend Systems",
		description:
			"Scalable APIs and core services with observability, domain modeling, and resilient integrations.",
	},
	{
		icon: "Ops",
		title: "Cloud Infrastructure",
		description:
			"Infrastructure and delivery pipelines that keep deployments reliable, secure, and easy to evolve.",
	},
];
---

<section id="services" class="section">
	<div class="container">
		<div class="section-head reveal">
			<span class="section-kicker">Services</span>
			<h2 class="section-title">
				Engineering support across product delivery, systems, and infrastructure.
			</h2>
		</div>
		<div class="services-grid">
			{
				services.map((service, index) => (
					<article class={`service-card reveal reveal-delay-${index + 1}`}>
						<span class="service-index">0{index + 1}</span>
						<h3>{service.title}</h3>
						<p>{service.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0;
		border-top: 1px solid var(--line-strong);
	}

	.service-card {
		padding: 1.35rem 1.1rem 1.5rem;
		display: grid;
		gap: 0.7rem;
		min-width: 0;
		border-bottom: 1px solid var(--border);
		transition:
			background-color 0.24s ease,
			border-color 0.24s ease;
	}

	.service-card:not(:first-child) {
		border-inline-start: 1px solid var(--border);
	}

	.service-card:hover {
		background: linear-gradient(180deg, transparent, var(--accent-wash));
		border-color: color-mix(in oklch, var(--accent) 20%, var(--border));
	}

	.service-index {
		font-family: var(--font-heading);
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.service-card h3 {
		font-size: 1.24rem;
		max-width: 14ch;
	}

	.service-card p {
		font-size: 0.97rem;
	}

	@media (max-width: 980px) {
		.services-grid {
			grid-template-columns: 1fr;
		}

		.service-card:not(:first-child) {
			border-inline-start: 0;
		}
	}
</style>
