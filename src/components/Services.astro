---
const services = [
	{
		icon: "Web",
		title: "Web Applications",
		description:
			"Product-grade frontends and full-stack experiences built for performance, usability, and long-term maintainability.",
	},
	{
		icon: "API",
		title: "Backend Systems",
		description:
			"Scalable APIs and core services with observability, domain modeling, and resilient integrations.",
	},
	{
		icon: "Ops",
		title: "Cloud Infrastructure",
		description:
			"Infrastructure and delivery pipelines that keep deployments reliable, secure, and easy to evolve.",
	},
];
---

<section id="services" class="section">
	<div class="container">
		<div class="section-head reveal">
			<span class="section-kicker">Services</span>
			<h2 class="section-title">Capabilities across product, platform, and operations.</h2>
		</div>
		<div class="services-grid">
			{
				services.map((service, index) => (
					<article class={`service-card glass-card reveal reveal-delay-${index + 1}`}>
						<h3>{service.title}</h3>
						<p>{service.description}</p>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.service-card {
		padding: 1.2rem;
		display: grid;
		gap: 0.65rem;
	}

	.service-card h3 {
		font-size: 1.24rem;
	}

	.service-card p {
		font-size: 0.97rem;
	}

	@media (max-width: 980px) {
		.services-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
