---

---

<section id="services" class="section">
	<div class="container">
		<h2 class="section-title">What We Do</h2>
		<div class="services-grid">
			<div class="service-card glass-card">
				<div class="service-icon">🌐</div>
				<h3>Web Applications</h3>
				<p>
					Dynamic, responsive, and high-performance web applications tailored to your business needs
					using the latest frontend technologies.
				</p>
			</div>

			<div class="service-card glass-card">
				<div class="service-icon">⚙️</div>
				<h3>Backend Applications</h3>
				<p>
					Secure, scalable, and efficient server-side architectures and APIs designed to handle
					complex business logic and heavy traffic.
				</p>
			</div>

			<div class="service-card glass-card">
				<div class="service-icon">☁️</div>
				<h3>Infrastructure</h3>
				<p>
					Cloud-native infrastructure solutions, deployment pipelines, and operational reliability
					to keep your applications running smoothly 24/7.
				</p>
			</div>
		</div>
	</div>
</section>

<style>
	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}
	.service-icon {
		font-size: 3rem;
		margin-bottom: 1.5rem;
	}
	.service-card h3 {
		font-size: 1.5rem;
		margin-bottom: 1rem;
	}
	@media (max-width: 768px) {
		.services-grid {
			grid-template-columns: 1fr;
		}
		.service-icon {
			font-size: 2rem;
			margin-bottom: 0.75rem;
		}
		.service-card h3 {
			font-size: 1.25rem;
		}
	}
</style>
