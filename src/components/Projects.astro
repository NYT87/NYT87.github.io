---

---

<section id="projects" class="section projects-section">
	<div class="container">
		<div class="section-head reveal">
			<span class="section-kicker">Selected Work</span>
			<h2 class="section-title">Recent work built for everyday use, not demo-day polish.</h2>
		</div>
		<div class="projects-grid">
			<a
				href="https://github.com/NYT87/booba-pass"
				target="_blank"
				rel="noopener noreferrer"
				class="project-card panel reveal reveal-delay-1"
			>
				<div class="project-head">
					<h3>Booba Pass</h3>
					<span class="project-tag">Open Source</span>
				</div>
				<p>
					A centralized wallet for airline loyalty information with QR and barcode support, designed
					for quick access and practical day-to-day use.
				</p>
				<span class="project-link">Review the codebase</span>
			</a>

			<article class="project-note reveal reveal-delay-2">
				<div class="project-head">
					<h3>More client work</h3>
				</div>
				<p>
					Private client systems and internal delivery tools are not public yet, but we can walk
					through relevant work in a conversation.
				</p>
				<span class="project-link muted">More examples available on request</span>
			</article>
		</div>
	</div>
</section>

<style>
	.projects-section {
		position: relative;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) minmax(220px, 0.8fr);
		gap: clamp(1rem, 2.5vw, 2rem);
		align-items: stretch;
	}

	.project-card {
		padding: clamp(1.3rem, 2.4vw, 1.7rem);
		display: grid;
		gap: 1rem;
		min-width: 0;
		transition:
			transform 0.24s ease,
			box-shadow 0.24s ease;
	}

	a.project-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 16px 30px color-mix(in oklch, var(--text) 12%, transparent);
	}

	a.project-card:active {
		transform: translateY(-1px);
	}

	.project-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.8rem;
		min-width: 0;
	}

	.project-head h3 {
		font-size: 1.32rem;
		min-width: 0;
	}

	.project-tag {
		font-family: var(--font-heading);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.3rem 0.55rem;
		border-radius: 999px;
		background: var(--brand-soft);
		color: var(--brand);
		white-space: nowrap;
		flex-shrink: 0;
	}

	.project-tag.soon {
		background: var(--accent-soft);
		color: var(--accent);
	}

	.project-link {
		font-family: var(--font-heading);
		font-size: 0.9rem;
		color: var(--brand);
		overflow-wrap: break-word;
	}

	.project-link.muted {
		color: var(--muted);
	}

	.project-note {
		padding: 0.6rem 0 0;
		display: grid;
		align-content: start;
		gap: 1rem;
		border-top: 1px solid var(--line-strong);
		max-width: 34ch;
	}

	@media (max-width: 900px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.project-head {
			flex-direction: column;
		}

		.project-tag {
			white-space: normal;
		}
	}
</style>
