---

---

<section id="projects" class="section projects-section">
	<div class="container">
		<div class="section-head reveal">
			<span class="section-kicker">Selected Work</span>
			<h2 class="section-title">Projects focused on utility, speed, and clarity.</h2>
		</div>
		<div class="projects-grid">
			<a
				href="https://github.com/NYT87/booba-pass"
				target="_blank"
				rel="noopener noreferrer"
				class="project-card panel reveal reveal-delay-1"
			>
				<div class="project-head">
					<h3>Booba Pass</h3>
					<span class="project-tag">Open Source</span>
				</div>
				<p>
					A centralized wallet for airline loyalty information with QR and barcode support, designed
					for quick access and practical day-to-day use.
				</p>
				<span class="project-link">View repository</span>
			</a>

			<article class="project-card panel placeholder reveal reveal-delay-2">
				<div class="project-head">
					<h3>More Launches</h3>
				</div>
				<p>
					Additional internal tools and client systems are in active development and will be
					published here soon.
				</p>
				<span class="project-link muted">Portfolio update coming soon</span>
			</article>
		</div>
	</div>
</section>

<style>
	.projects-section {
		position: relative;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.project-card {
		padding: 1.3rem;
		display: grid;
		gap: 1rem;
		transition:
			transform 0.24s ease,
			box-shadow 0.24s ease;
	}

	a.project-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 16px 30px color-mix(in oklch, var(--text) 12%, transparent);
	}

	.project-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 0.8rem;
	}

	.project-head h3 {
		font-size: 1.32rem;
		min-width: 0;
	}

	.project-tag {
		font-family: var(--font-heading);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.3rem 0.55rem;
		border-radius: 999px;
		background: var(--brand-soft);
		color: var(--brand);
		white-space: nowrap;
		flex-shrink: 0;
	}

	.project-tag.soon {
		background: var(--accent-soft);
		color: var(--accent);
	}

	.project-link {
		font-family: var(--font-heading);
		font-size: 0.9rem;
		color: var(--brand);
	}

	.project-link.muted {
		color: var(--muted);
	}

	.placeholder {
		opacity: 0.92;
	}

	@media (max-width: 900px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 520px) {
		.project-head {
			flex-direction: column;
		}
	}
</style>
