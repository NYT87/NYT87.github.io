---
import { Image } from "astro:assets";
import joseImg from "../assets/jose.jpeg";
---

<section id="team" class="section">
	<div class="container">
		<div class="section-head reveal">
			<span class="section-kicker">Team</span>
			<h2 class="section-title">Senior engineering leadership with product discipline.</h2>
		</div>
		<article class="team-card panel reveal reveal-delay-1">
			<div class="team-top">
				<Image src={joseImg} alt="José Miguel" class="team-avatar" />
				<div class="team-meta">
					<h3>José Miguel</h3>
					<p class="team-role">CTO & Senior Software Engineer</p>
					<a
						href="https://www.linkedin.com/in/jm8nav/"
						target="_blank"
						rel="noopener noreferrer"
						class="team-link"
					>
						LinkedIn profile
					</a>
				</div>
			</div>
			<p class="team-desc">
				José Miguel Navarro Iglesias builds software at the intersection of product delivery,
				reliable architecture, and scaling strategy. He has led backend and full-stack initiatives
				that turn ambitious ideas into fast, stable systems ready for growth.
			</p>
		</article>
	</div>
</section>

<style>
	.team-card {
		padding: clamp(1.2rem, 2.6vw, 2rem);
		display: grid;
		gap: 1rem;
	}

	.team-top {
		display: flex;
		gap: 1rem;
		align-items: center;
	}

	.team-avatar {
		width: 98px;
		height: 98px;
		aspect-ratio: 1 / 1;
		border-radius: 22px;
		object-fit: cover;
		border: 1px solid rgba(13, 138, 138, 0.3);
	}

	.team-meta {
		display: grid;
		gap: 0.38rem;
	}

	.team-meta h3 {
		font-size: 1.3rem;
	}

	.team-role {
		font-size: 0.98rem;
		color: var(--brand);
		font-weight: 700;
	}

	.team-link {
		font-family: var(--font-heading);
		font-size: 0.86rem;
		color: #066a6a;
	}

	.team-desc {
		font-size: 0.98rem;
		max-width: 80ch;
	}

	@media (max-width: 768px) {
		.team-top {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
