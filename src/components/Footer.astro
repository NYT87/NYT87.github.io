---

---

<footer id="contact" class="footer section">
	<div class="container footer-panel panel reveal">
		<div class="footer-links">
			<div>
				<h4>Contact</h4>
				<a href="mailto:nyt87@proton.me">nyt87@proton.me</a>
			</div>
			<div>
				<h4>GitHub</h4>
				<a href="https://github.com/NYT87" target="_blank" rel="noopener noreferrer">NYT87</a>
			</div>
		</div>
		<div class="footer-brand">
			<img src="/assets/logo-text.png" alt="NYT87" class="footer-logo" />
		</div>
	</div>
	<div class="container footer-bottom">
		<p>&copy; {new Date().getFullYear()} NYT87. All rights reserved.</p>
	</div>
</footer>

<style>
	.footer {
		padding-top: 2.4rem;
		padding-bottom: clamp(2rem, 4vw, 3.5rem);
	}

	.footer-panel {
		padding: 1.2rem;
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		gap: 1.1rem;
		text-align: left;
	}

	.footer-brand {
		display: flex;
		justify-content: flex-end;
	}

	.footer-logo {
		height: 24px;
		width: auto;
	}

	.footer-links {
		display: flex;
		align-items: flex-start;
		justify-content: flex-start;
		gap: 2rem;
		width: auto;
	}

	.footer-links h4 {
		font-size: 0.92rem;
		text-transform: uppercase;
		letter-spacing: 0.07em;
		margin-bottom: 0.5rem;
	}

	.footer-links a {
		color: #066a6a;
		font-weight: 700;
	}

	.footer-bottom {
		padding: 1rem 0 0.2rem;
		text-align: center;
	}

	.footer-bottom p {
		font-size: 0.84rem;
	}

	@media (max-width: 860px) {
		.footer-panel {
			flex-direction: column;
			align-items: flex-start;
		}

		.footer-links {
			gap: 1.3rem;
		}
	}

	@media (max-width: 560px) {
		.footer-brand {
			align-self: flex-end;
			justify-content: flex-end;
		}

		.footer-links {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.9rem;
		}
	}
</style>
