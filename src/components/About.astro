---

---

<section id="about" class="section about-section">
	<div class="container">
		<div class="section-head reveal">
			<span class="section-kicker">About NYT87</span>
			<h2 class="section-title">A delivery partner for teams building serious software.</h2>
		</div>
		<div class="about-grid">
			<article class="about-text reveal reveal-delay-1">
				<h3>From MVPs to production platforms</h3>
				<p>
					We work with startups and established teams to turn ambiguous product ideas into clear,
					testable software outcomes. Our process emphasizes maintainable architecture and
					predictable delivery.
				</p>
				<p>
					Because we are fully remote and async-capable, we integrate directly into your workflow,
					align around measurable milestones, and keep technical execution transparent from day one.
				</p>
			</article>
			<aside class="about-visual reveal reveal-delay-2" aria-hidden="true">
				<div class="visual-card">
					<img src="/assets/logo-icon.png" alt="" class="about-logo" />
					<span class="visual-label">Studio Mark</span>
					<p>Engineering quality, clear communication, and business impact.</p>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.about-section {
		position: relative;
	}

	.about-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
		gap: clamp(1.2rem, 3vw, 3rem);
		align-items: stretch;
	}

	.about-text {
		padding: clamp(0.3rem, 0.8vw, 0.6rem) 0 0;
		display: grid;
		gap: 1.15rem;
		min-width: 0;
		max-width: 60ch;
	}

	.about-text h3 {
		font-size: clamp(1.35rem, 1rem + 1vw, 2.1rem);
		max-width: 15ch;
	}

	.about-visual {
		display: flex;
		align-items: stretch;
		min-width: 0;
	}

	.visual-card {
		padding: clamp(1.25rem, 2.2vw, 1.7rem);
		display: grid;
		align-content: center;
		justify-items: start;
		gap: 0.9rem;
		text-align: left;
		width: 100%;
		min-height: 100%;
		border-top: 1px solid var(--line-strong);
		border-bottom: 1px solid var(--border);
		background: linear-gradient(180deg, transparent, var(--accent-wash));
	}

	.about-logo {
		width: clamp(110px, 14vw, 150px);
		height: auto;
		filter: drop-shadow(0 10px 20px var(--brand-shadow));
	}

	.visual-label {
		font-family: var(--font-heading);
		font-size: 0.76rem;
		font-weight: 500;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: color-mix(in oklch, var(--accent) 68%, var(--text));
	}

	.visual-card p {
		max-width: 26ch;
		font-size: 0.98rem;
		overflow-wrap: break-word;
	}

	@media (max-width: 900px) {
		.about-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
