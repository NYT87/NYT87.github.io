---

---

<section id="about" class="section about-section">
	<div class="container">
		<div class="section-head reveal">
			<span class="section-kicker">About NYT87</span>
			<h2 class="section-title">A delivery partner for teams building serious software.</h2>
		</div>
		<div class="about-grid">
			<article class="about-text panel reveal reveal-delay-1">
				<h3>From MVPs to production platforms</h3>
				<p>
					We work with startups and established teams to turn ambiguous product ideas into clear,
					testable software outcomes. Our process emphasizes maintainable architecture and
					predictable delivery.
				</p>
				<p>
					Because we are fully remote and async-capable, we integrate directly into your workflow,
					align around measurable milestones, and keep technical execution transparent from day one.
				</p>
			</article>
			<aside class="about-visual reveal reveal-delay-2" aria-hidden="true">
				<div class="visual-card glass-card">
					<img src="/assets/logo-icon.png" alt="" class="about-logo" />
					<p>Engineering quality, clear communication, and business impact.</p>
				</div>
			</aside>
		</div>
	</div>
</section>

<style>
	.about-section {
		position: relative;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1.25fr 0.75fr;
		gap: clamp(1rem, 2.5vw, 2rem);
		align-items: stretch;
	}

	.about-text {
		padding: clamp(1.3rem, 2.3vw, 2rem);
		display: grid;
		gap: 1rem;
		min-width: 0;
	}

	.about-text h3 {
		font-size: clamp(1.3rem, 1rem + 1vw, 2rem);
	}

	.about-visual {
		display: flex;
		align-items: stretch;
		min-width: 0;
	}

	.visual-card {
		padding: 1.3rem;
		display: grid;
		align-content: center;
		justify-items: center;
		gap: 1rem;
		text-align: center;
		width: 100%;
	}

	.about-logo {
		width: clamp(110px, 14vw, 150px);
		height: auto;
		filter: drop-shadow(0 10px 20px rgba(13, 138, 138, 0.24));
	}

	.visual-card p {
		max-width: 24ch;
		font-size: 0.95rem;
		overflow-wrap: break-word;
	}

	@media (max-width: 900px) {
		.about-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
